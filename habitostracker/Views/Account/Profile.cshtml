@model HabitTrackerApp.Models.User

@{
    ViewData["Title"] = "Mi Perfil";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />

<h3 class="mb-4 fw-bold">👤 Mi Perfil</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}



<div class="text-center mb-4">

   @if (!string.IsNullOrEmpty(Model.ProfileImage))
{
    <img id="previewImage"
         src="@Model.ProfileImage?v=@DateTime.Now.Ticks"
         class="rounded-circle shadow"
         style="width:120px;height:120px;object-fit:cover;" />
}
else
{
    <div id="previewLetter"
         class="rounded-circle shadow d-flex align-items-center justify-content-center"
         style="width:120px;height:120px;
                background:linear-gradient(135deg,#2563eb,#7c3aed);
                color:white;
                font-size:40px;
                font-weight:bold;
                margin:auto;">

        @Model.Username.Substring(0,1).ToUpper()

    </div>
}
    

</div>

<button type="button"
        id="removePhotoBtn"
        data-no-loader
        class="btn btn-outline-danger rounded-pill px-4 ms-2">
    🗑️ Eliminar foto
</button>


<!-- ================================================= -->
<!-- FORMULARIO DEL PERFIL -->
<!-- ================================================= -->

<form asp-controller="Account"
      asp-action="Profile"
      method="post"
      enctype="multipart/form-data"
      data-no-loader>

    @Html.AntiForgeryToken()

    <input type="hidden" id="croppedImageInput" name="croppedImage" />

    <div class="mb-3">

        <label class="form-label">Foto de perfil</label>

        <div class="d-flex justify-content-center gap-5 mt-4 mb-3">

            <!-- 🔥 SEGUIDORES / SIGUIENDO -->
 

            <div class="d-flex justify-content-center gap-5 mt-4 mb-3">

                <div class="text-center"
                     style="cursor:pointer"
                     onclick="if(@ViewBag.Followers > 0) openModal('followers')">

                    <div class="fw-bold fs-5">@ViewBag.Followers</div>
                    <small class="text-muted">Seguidores</small>
                </div>

                <div class="text-center"
                     style="cursor:pointer"
                     onclick="if(@ViewBag.Following > 0) openModal('following')">

                    <div class="fw-bold fs-5">@ViewBag.Following</div>
                    <small class="text-muted">Siguiendo</small>
                </div>

            </div>

        </div>

        <input type="file"
               id="imageInput"
               name="profilePhoto"
               class="form-control"
               accept="image/*" />

    </div>

   

    <!-- ======================= -->
    <!-- RECORTE DE IMAGEN -->
    <!-- ======================= -->

    <div class="text-center">

        <img id="cropImage"
             style="max-width:300px; display:none; margin-top:20px;" />

        <br>

        <button type="button"
                id="cropButton"
                data-no-loader
                class="btn btn-success mt-3"
                style="display:none;">
            Recortar imagen
        </button>

    </div>

    <div class="mb-3 mt-4">

        <label class="form-label">Usuario</label>

        <input class="form-control"
               value="@Model.Username"
               disabled />

               @if (Model.IsGoogleAccount)
{
    <div class="alert alert-info mt-2">
        🔵 Cuenta creada con Google
    </div>
}

    </div>

    <div class="mb-3">

        <label class="form-label">Nombre completo</label>

        <input asp-for="FullName"
               class="form-control" />

    </div>

    <div class="mb-3">

       
        <div class="mb-3">
            <label class="form-label">Correo electrónico</label>
            <input asp-for="Email" class="form-control" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">Cuéntanos sobre ti</label>
            <textarea asp-for="Bio" class="form-control" rows="3" placeholder="Escribe algo sobre ti..."></textarea>
        </div>

     

    </div>

    <div class="mb-3">

        <label class="form-label">Miembro desde</label>
        <input class="form-control" value="@Model.CreatedAt?.ToString("dd/MM/yyyy")" disabled />

        <br>
        <br>

    <button type="submit"
            class="btn btn-primary rounded-pill px-4">
        💾 Guardar cambios
    </button>

    <!-- ============================== -->
    <!-- NUEVO BOTÓN ELIMINAR FOTO -->
    <!-- ============================== -->

</form>


    <!-- 🔥 MODAL SEGUIDORES -->
   <div id="followModal" class="follow-modal" style="display:none;">
        <div class="follow-content">
            <div class="follow-header">
                <span id="modalTitle">Usuarios</span>
                <span class="close-btn" onclick="closeModal()">✖</span>
            </div>
            <div id="followList"></div>
        </div>
    </div>



    <style>

        .follow-modal {
            display: none;
            position: fixed;
            z-index: 9999;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex;
            justify-content: center;
            align-items: center;
        }

   .follow-content {
    background: #fff;
    color: #000;
    border-radius: 12px;
    padding: 10px;
}
.follow-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px;
    border-radius: 8px;
    cursor: pointer;
    background: transparent;
    color: #000;
}

.follow-item span,
.follow-item div {
    color: inherit;
}

.follow-modal {
    background: rgba(0,0,0,0.6);
}

body.dark-mode .follow-item {
    color: #e5e7eb;
}

body.dark-mode .follow-item:hover {
    background: #1f2937;
}

/* hover */
.follow-item:hover {
    background: #f3f4f6;
}


body.dark-mode .follow-content {
    background: #111827; /* 🔥 oscuro real */
    color: #e5e7eb;
}


@@keyframes fadeIn {
    from {
        transform: scale(0.9);
        opacity: 0;
    }
    to {
        transform: scale(1);
        opacity: 1;
    }
}
.follow-header {
   
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    margin-bottom: 10px;
}

.close-btn {
    cursor: pointer;
    font-size: 18px;
}

    </style>


<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<script>

    let cropper;

    const input = document.getElementById("imageInput");
    const image = document.getElementById("cropImage");
    let preview = document.getElementById("previewImage");
    const hiddenInput = document.getElementById("croppedImageInput");
    const cropButton = document.getElementById("cropButton");

    input.addEventListener("change", function(e){

    const file = e.target.files[0];

    if(!file) return;

    const reader = new FileReader();

    reader.onload = function(event){

    image.src = event.target.result;

    image.style.display = "block";
    cropButton.style.display = "inline-block";

    if(cropper){
    cropper.destroy();
    }

    cropper = new Cropper(image,{
    aspectRatio:1,
    viewMode:1,
    autoCropArea:1,
    zoomable:true,
    movable:true,
    zoomOnWheel:true
    });

    };

    reader.readAsDataURL(file);

    });

    cropButton.addEventListener("click", function(){

    if(!cropper) return;

    const canvas = cropper.getCroppedCanvas({
    width:300,
    height:300
    });

    const base64 = canvas.toDataURL("image/png");

        if(!preview){

        const letter = document.getElementById("previewLetter");
        if(letter) letter.remove();

        const img = document.createElement("img");

        img.id="previewImage";
        img.className="rounded-circle shadow";
        img.style.width="120px";
        img.style.height="120px";
        img.style.objectFit="cover";

        document.querySelector(".text-center.mb-4").appendChild(img);

        preview = img;

    }

    preview.src = base64;

    hiddenInput.value = base64;

    const navbarAvatar = document.querySelector(".user-avatar-img");

    if(navbarAvatar){
    navbarAvatar.src = base64;
    }

    image.style.display = "none";
    cropButton.style.display = "none";

    cropper.destroy();
    cropper = null;

    });

    /* ================================= */
    /* ELIMINAR FOTO (MEJORADO) */
    /* ================================= */

    const removeBtn = document.getElementById("removePhotoBtn");

    removeBtn.addEventListener("click", function(){

        hiddenInput.value = "REMOVE";

        preview.style.display="none";

        const oldLetter=document.getElementById("previewLetter");

        if(oldLetter) return;

        const letter=document.createElement("div");

        letter.id="previewLetter";

        letter.className="rounded-circle shadow d-flex align-items-center justify-content-center";

        letter.style.width="120px";
        letter.style.height="120px";
        letter.style.background="linear-gradient(135deg,#2563eb,#7c3aed)";
        letter.style.color="white";
        letter.style.fontSize="40px";
        letter.style.fontWeight="bold";
        letter.style.margin="auto";

        letter.innerText="@Model.Username.Substring(0, 1).ToUpper()";

        preview.parentElement.appendChild(letter);

    });

</script>

    <script>
        function openModal(type){
        const modal = document.getElementById("followModal");
        const list = document.getElementById("followList");
        const title = document.getElementById("modalTitle");

       modal.style.display = "flex";
        list.innerHTML = "Cargando...";

        if(type === "followers"){
        title.innerText = "Seguidores";
        fetch(`/User/GetFollowers?userId=@Model.Id`)
        .then(r => r.text())
        .then(data => list.innerHTML = data);
        }else{
        title.innerText = "Siguiendo";
        fetch(`/User/GetFollowing?userId=@Model.Id`)
        .then(r => r.text())
        .then(data => list.innerHTML = data);
        }
        }

        function closeModal(){
        document.getElementById("followModal").style.display = "none";
        }
    </script>