<div class="upgrade-container">

    <h2 class="text-center mb-2">🔓 Completa tu cuenta</h2>
    <p class="text-center text-muted mb-4">
        Convierte tu cuenta de invitado en una cuenta completa
    </p>

    <!-- 🔥 BOTÓN GOOGLE -->
    <a href="/Account/GoogleLogin" class="btn google-btn w-100 mb-3">
        <img src="https://developers.google.com/identity/images/g-logo.png"
             style="width:18px; margin-right:8px;">
        Continuar con Google
    </a>

    <div class="text-center mb-3 text-muted">o</div>

    <!-- 🔥 FORMULARIO -->
    <form method="post" asp-action="UpgradeAccount">

        <div class="mb-3">
            <label>Correo electrónico</label>
            <input name="email" type="email" class="form-control" required />
        </div>

        <div class="mb-3">
            <label>Contraseña</label>
            <input name="password" type="password" class="form-control" required />
        </div>

        <button class="btn btn-primary w-100">
            🚀 Crear cuenta
        </button>
    </form>

</div>

<style>
    .upgrade-container {
        max-width: 400px;
        margin: auto;
        padding: 25px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    /* 🔥 botón Google estilo moderno */
    .google-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 10px;
        font-weight: 500;
        padding: 10px;
        transition: 0.2s;
    }

        .google-btn:hover {
            background: #f5f5f5;
            transform: scale(1.02);
        }
</style>