<div class="guest-container">

    <h2 class="text-center mb-2">👤 Modo Invitado</h2>
    <p class="text-center text-muted mb-4">
        Estás entrando con acceso limitado
    </p>

    <!-- 🔥 MENSAJES DE ERROR -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger text-center">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <div class="guest-info mb-4">
        <p>⚠ Algunas funciones no estarán disponibles:</p>
        <ul>
            <li>❌ Enviar mensajes</li>
            <li>❌ Agregar amigos</li>
            <li>❌ Comentar o publicar</li>
            <li>❌ Subir fotos</li>
        </ul>
    </div>

    <form method="post">

        <div class="mb-3">
            <label>Crear Nombre de usuario</label>
            <input name="username" class="form-control" placeholder="Ej: Invitado123" required />
        </div>

        <button class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2 py-2 fw-semibold guest-btn">
            <span>🚀</span>
            <span>Continuar como invitado</span>
        </button>
    </form>

    <hr class="my-4" />

    <h5 class="text-center">🔁 ¿Ya entraste como invitado antes?</h5>

    <form method="post" asp-action="GuestLoginExisting">
        <div class="mb-3">
            <input name="username" class="form-control" placeholder="Tu usuario" required />
        </div>

        <button class="btn btn-outline-secondary w-100">
            🔓 Entrar con mi usuario invitado
        </button>
    </form>

    <p class="text-center mt-3 small text-muted">
        Puedes crear una cuenta más adelante para desbloquear todas las funciones
    </p>

</div>

<style>
    .guest-container {
        max-width: 400px;
        margin: auto;
        padding: 25px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .guest-info {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 10px;
        font-size: 14px;
    }

        .guest-info ul {
            padding-left: 18px;
            margin: 0;
        }

        .guest-info li {
            margin-bottom: 5px;
        }

    .guest-btn {
        background: linear-gradient(135deg, #4e73df, #224abe);
        border: none;
    }

    .guest-btn {
        border-radius: 12px;
        transition: all 0.3s ease;
        font-size: 15px;
    }

        .guest-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }

        .guest-btn:active {
            transform: scale(0.98);
        }

    /* 🔥 mejora visual del error */
    .alert {
        border-radius: 10px;
        font-size: 14px;
    }
</style>
