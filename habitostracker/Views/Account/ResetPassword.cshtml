@model HabitTrackerApp.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Nueva contraseña";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">

    <div class="card shadow-lg border-0 rounded-4 p-4" style="width:100%;max-width:400px;">

        <div class="text-center mb-3">
            <h3 class="fw-bold">🔐 Nueva contraseña</h3>
            <p class="text-muted small">Crea una contraseña segura</p>
        </div>

        <form asp-action="ResetPassword" method="post">

            <input type="hidden" asp-for="Email" />

            <div class="mb-3">
                <label class="form-label">Nueva contraseña</label>
                <input asp-for="Password" type="password"
                       class="form-control rounded-pill" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Confirmar contraseña</label>
                <input asp-for="ConfirmPassword" type="password"
                       class="form-control rounded-pill" required />
            </div>

            <button type="submit"
                    class="btn btn-primary w-100 rounded-pill shadow-sm">
                🔄 Actualizar contraseña
            </button>

        </form>

    </div>

</div>