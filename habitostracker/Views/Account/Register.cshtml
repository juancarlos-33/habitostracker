@model HabitTrackerApp.Models.RegisterViewModel

@{
    ViewData["Title"] = "Registro";
    Layout = "_LayoutLogin";
}

<div class="container mt-5" style="max-width:400px;">
    <div class="card shadow rounded-4 p-4 border-0">

        <h3 class="text-center mb-4">📝 Crear Cuenta</h3>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <form asp-action="Register" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="mb-3 text-center">
                <label class="form-label">Foto de perfil (opcional)</label>

                <input type="file" name="profilePhoto" id="imageInput" class="form-control" accept="image/*" formnovalidate />
                <!-- PREVIEW -->
                <img id="previewImage"
                     style="width:100px;height:100px;border-radius:50%;object-fit:cover;margin-top:10px;display:none;" />
            </div>

            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <input asp-for="Username" class="form-control" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Correo</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Género</label>
                <select asp-for="Gender" class="form-select">
                    <option value="">Seleccionar</option>
                    <option value="Masculino">Masculino</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Therian">Therian</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Nombre completo</label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Cuéntanos sobre ti</label>
                <textarea asp-for="Bio" class="form-control" rows="3" placeholder="Escribe algo sobre ti..."></textarea>
                <span asp-validation-for="Bio" class="text-danger"></span>
            </div>



            <button type="submit" class="btn btn-primary w-100 rounded-pill">
                Registrarme
            </button>

        </form>

        <div class="text-center mt-3">
            <a asp-action="Login">
                ¿Ya tienes cuenta? Inicia sesión
            </a>
        </div>

    </div>
</div>

<script>
    document.getElementById("imageInput").addEventListener("change", function(e){
        const file = e.target.files[0];
        if(!file) return;

        const reader = new FileReader();
        reader.onload = function(event){
            const img = document.getElementById("previewImage");
            img.src = event.target.result;
            img.style.display = "block";
        };
        reader.readAsDataURL(file);
    });
</script>
