@model HabitTrackerApp.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Cambiar contraseña";
    Layout = "_LayoutLogin";
}

<div class="container mt-5" style="max-width:500px;">

    <div class="card shadow rounded-4 border-0">
        <div class="card-body p-4">

            <h3 class="text-center mb-4 fw-bold">🔐 Cambiar contraseña</h3>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Contraseña actual</label>
                    <input asp-for="CurrentPassword"
                           type="password"
                           class="form-control rounded-pill" />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nueva contraseña</label>
                    <input asp-for="NewPassword"
                           type="password"
                           class="form-control rounded-pill" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirmar nueva contraseña</label>
                    <input asp-for="ConfirmPassword"
                           type="password"
                           class="form-control rounded-pill" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit"
                        class="btn btn-primary w-100 rounded-pill shadow-sm">
                    Actualizar contraseña
                </button>

                <div class="text-center mt-3">
                    <a asp-action="Profile" class="text-decoration-none">
                        ← Volver al perfil
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>