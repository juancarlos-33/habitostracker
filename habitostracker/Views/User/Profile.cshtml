@model HabitTrackerApp.Models.User

@{
    ViewData["Title"] = "Perfil de usuario";

    var myId = int.Parse(User.FindFirst("UserId").Value);

    var db = Context.RequestServices.GetService<HabitTrackerApp.Data.HabitDbContext>();

    var isFollowing = db.Follows
        .Any(f => f.FollowerId == myId && f.FollowingId == Model.Id);
}

<div class="container mt-4" style="max-width:600px;">

    <div class="card shadow p-4 text-center">

        <h3 class="mb-3">👤 Perfil de @Model.Username</h3>

        @if (Model.ProfileImage != null)
        {
            <img src="@Model.ProfileImage"
                 width="120"
                 height="120"
                 style="border-radius:50%; object-fit:cover;" />
        }
        else
        {
            <div style="font-size:80px;">👤</div>
        }

        <div class="mt-3">

            <p><strong>Nombre:</strong> @Model.FullName</p>

            <p><strong>Miembro desde:</strong> @Model.CreatedAt?.ToShortDateString()</p>

        </div>

        <!-- SEGUIDORES / SIGUIENDO -->

        <div class="d-flex justify-content-center gap-4 mt-3">
            <div class="text-center">
                <div class="fw-bold">@ViewBag.FollowersCount</div>
                <small>Seguidores</small>
            </div>

            <div class="text-center">
                <div class="fw-bold">@ViewBag.FollowingCount</div>
                <small>Siguiendo</small>
            </div>
        </div>

        <!-- BOTÓN SEGUIR -->
        @if (Model.Id != myId)
        {
            if (isFollowing)
            {
                <form asp-controller="User" asp-action="Unfollow" method="post" class="mt-3">

                    <input type="hidden" name="userId" value="@Model.Id" />

                    <button class="btn btn-secondary">
                        Siguiendo
                    </button>

                </form>
            }
            else
            {
                <form asp-controller="User" asp-action="Follow" method="post" class="mt-3">

                    <input type="hidden" name="userId" value="@Model.Id" />

                    <button class="btn btn-primary">
                        Seguir
                    </button>

                </form>
            }
        }

    </div>

    <div class="mt-4">

        <form asp-action="SendFriendRequest" method="post">

            <input type="hidden" name="receiverId" value="@Model.Id" />

            <button type="submit" class="btn btn-success">
                ➕ Agregar amigo
            </button>

        </form>

        <!-- MENSAJE -->

        <a asp-controller="Message"
           asp-action="Chat"
           asp-route-userId="@Model.Id"
           class="btn btn-primary btn-sm mt-3">
            💬 Enviar mensaje
        </a>

    </div>

</div>