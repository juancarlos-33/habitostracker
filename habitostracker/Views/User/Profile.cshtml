@model HabitTrackerApp.Models.User
@{
    ViewData["Title"] = "Perfil de usuario";
    var myId = int.Parse(User.FindFirst("UserId").Value);
    var db = Context.RequestServices.GetService<HabitTrackerApp.Data.HabitDbContext>();
    var isFollowing = db.Follows.Any(f => f.FollowerId == myId && f.FollowingId == Model.Id);
    var friendStatus = db.FriendRequests
    .Where(f => (f.SenderId == myId && f.ReceiverId == Model.Id) ||
                (f.SenderId == Model.Id && f.ReceiverId == myId))
    .Select(f => f.Status)
    .FirstOrDefault();
}

<div class="container mt-4">

    <div class="profile-card text-center bg-white text-dark">

        <h3 class="mb-3">Perfil de @Model.Username</h3>

        <!-- FOTO -->
        <div class="profile-img-container">
            @if (!string.IsNullOrEmpty(Model.ProfileImage))
            {
                <img src="@Model.ProfileImage" class="profile-img" />
            }
            else
            {
                <div class="profile-placeholder">
                    @Model.Username.Substring(0, 1).ToUpper()
                </div>
            }
        </div>

        <!-- INFO -->
        <div class="mt-3">

            @if (!string.IsNullOrEmpty(Model.FullName))
            {
                <div class="profile-name">@Model.FullName</div>
            }

            @if (!string.IsNullOrEmpty(Model.Bio))
            {
                <div class="profile-bio-box">
                    <div class="profile-bio-title">Descripción</div>
                    <div class="profile-bio">@Model.Bio</div>
                </div>
            }

            <small class="text-muted">
                Se unió el @Model.CreatedAt?.ToString("dd MMM yyyy")
            </small>

        </div>

        <!-- STATS -->
        <div class="profile-stats">
            <div onclick="if(@ViewBag.Followers > 0) openModal('followers')">
                <strong>@ViewBag.Followers</strong>
                <span>Seguidores</span>
            </div>
            <div onclick="if(@ViewBag.Following > 0) openModal('following')">
                <strong>@ViewBag.Following</strong>
                <span>Siguiendo</span>
            </div>
        </div>

        <!-- BOTONES -->
        <div class="profile-actions mt-3">

            @if (Model.Id != myId)
            {
                if (isFollowing)
                {
                    <form asp-controller="User" asp-action="Unfollow" method="post">
                        <input type="hidden" name="userId" value="@Model.Id" />
                        <button class="btn-following">Siguiendo</button>
                    </form>
                }
                else
                {
                    <form asp-controller="User" asp-action="Follow" method="post">
                        <input type="hidden" name="userId" value="@Model.Id" />
                        <button class="btn-follow">Seguir</button>
                    </form>
                }
            }

            @if (friendStatus == "Accepted")
            {
                <button class="btn-add" style="background:#6b7280;" disabled>✅ Ya son amigos</button>
            }
            else if (friendStatus == "Pending")
            {
                <button class="btn-add" style="background:#f59e0b;" disabled>⏳ Solicitud enviada</button>
            }
            else
            {
                <form asp-action="SendFriendRequest" method="post" class="guest-block-form">
                    <input type="hidden" name="receiverId" value="@Model.Id" />
                    <button class="btn-add">Agregar</button>
                </form>
            }

            <a asp-controller="Message" asp-action="Chat" asp-route-userId="@Model.Id" class="btn-message">
                Mensaje
            </a>

        </div>

    </div>

</div>

<!-- 🔥 MODAL CENTRADO -->
<div id="followModal" class="follow-modal">
    <div class="follow-content">
        <div class="follow-header">
            <span id="modalTitle">Usuarios</span>
            <span class="close-btn" onclick="closeModal()">✖</span>
        </div>
        <div id="followList"></div>
    </div>
</div>

<style>

    /* CARD */
    .profile-card {
        max-width: 420px;
        margin: auto;
        padding: 30px 20px;
        border-radius: 20px;
        background: #fff;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
    }

   
    /* FOTO */
    .profile-img-container {
        display: flex;
        justify-content: center;
    }

    .profile-img, .profile-placeholder {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
    }

    /* 🔥 PERFIL EN MODO OSCURO */
    body.bg-dark .profile-card {
        background-color: #1e1e1e !important;
        color: #fff !important;
    }

        /* 🔥 TODO el contenido */
        body.bg-dark .profile-card * {
            color: #fff !important;
        }


    .profile-placeholder {
        background: linear-gradient(135deg,#ff416c,#ff4b2b);
        color: white;
        font-size: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* INFO */
    .profile-name {
        font-weight: 600;
        margin-top: 5px;
    }

    .profile-bio {
        font-size: 14px;
        color: #555;
        margin-top: 4px;
    }

    /* STATS */
    .profile-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-top: 20px;
    }

        .profile-stats div {
            cursor: pointer;
        }

    /* BOTONES */
    .profile-actions {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-follow {
        background: #0095f6;
        color: white;
        border: none;
        padding: 7px 14px;
        border-radius: 8px;
    }

    .btn-following {
        background: #efefef;
        border: none;
        padding: 7px 14px;
        border-radius: 8px;
    }

    .profile-bio-title {
        font-weight: 600;
        margin-top: 8px;
    }

    .profile-bio {
        font-size: 14px;
        color: #555;
        margin-top: 3px;
    }




    .btn-add {
        background: #22c55e;
        color: white;
        border: none;
        padding: 7px 14px;
        border-radius: 8px;
    }

    .btn-message {
        background: #e5e7eb;
        padding: 7px 14px;
        border-radius: 8px;
        text-decoration: none;
        color: black;
    }

    /* 🔥 MODAL BONITO */
    .follow-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
    }

    .follow-content {
        background: white;
        width: 320px;
        margin: 10% auto;
        border-radius: 12px;
        padding: 15px;
    }

    .follow-header {
        display: flex;
        justify-content: space-between;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .close-btn {
        cursor: pointer;
    }
</style>

<script>

    function openModal(type){
        const modal = document.getElementById("followModal");
        const list = document.getElementById("followList");
        const title = document.getElementById("modalTitle");

        modal.style.display = "block";
        list.innerHTML = "Cargando...";

        if(type === "followers"){
            title.innerText = "Seguidores";
            fetch(`/User/GetFollowers?userId=@Model.Id`)
            .then(r => r.text())
            .then(data => list.innerHTML = data);
        }else{
            title.innerText = "Siguiendo";
            fetch(`/User/GetFollowing?userId=@Model.Id`)
            .then(r => r.text())
            .then(data => list.innerHTML = data);
        }
    }

    function closeModal(){
        document.getElementById("followModal").style.display = "none";
    }

</script>