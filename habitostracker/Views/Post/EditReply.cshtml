@model HabitTrackerApp.Models.CommentReply

<h3 class="mb-4">✏️ Editar respuesta</h3>

<form asp-controller="Post"
      asp-action="UpdateReply"
      method="post">

    <input type="hidden" name="Id" value="@Model.Id" />
    <input type="hidden" name="CommentId" value="@Model.CommentId" />

    <div class="mb-3">

        <label class="form-label">Respuesta</label>

        <textarea name="Text"
                  class="form-control"
                  rows="3"
                  required>@Model.Text</textarea>

    </div>

    <button class="btn btn-success">
        💾 Guardar cambios
    </button>

    <a asp-controller="Post"
       asp-action="Index"
       class="btn btn-secondary">

        Cancelar

    </a>

</form>