@{
    ViewData["Title"] = "Nueva publicación";
}

<h2 class="mb-4">📸 Nueva publicación</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">

    <div class="mb-3">
        <label class="form-label">Descripción</label>
        <textarea name="description" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Subir foto</label>
        <input type="file" name="image" class="form-control" />
    </div>

    <button type="submit" id="btnComment" class="btn btn-primary">
        Publicar
    </button>
</form>
<script>
    document.querySelector("form").addEventListener("submit", function (e) {

        const text = this.querySelector("textarea")?.value.trim() || "";
        const imageInput = this.querySelector("input[type='file']");
        const hasImage = imageInput && imageInput.files.length > 0;

        if (text === "" && !hasImage) {
            e.preventDefault();
            alert("Debes escribir algo o subir una imagen.");
        }

    });
</script>