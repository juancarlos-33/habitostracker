@model List<HabitTrackerApp.Models.Habit>
@inject HabitTrackerApp.Data.HabitDbContext _context

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@{
    var username = User.Identity?.Name ?? "";
    var user = _context.Users.FirstOrDefault(u => u.Username == username);

    var habits = Model;

    int totalHabits = habits.Count();
    int totalStreak = habits.Sum(h => h.StreakDays);
    int bestRecord = habits.Any() ? habits.Max(h => h.MaxStreak) : 0;

    int completedToday = habits.Count(h =>
        h.LastCheckDate == DateTime.Today && h.Completed);

    int completionRate = totalHabits > 0
        ? (int)((completedToday * 100.0) / totalHabits)
        : 0;

    string welcomeMessage = "";
    string welcomeClass = "welcome-neutral";

    if (user != null)
    {
        if (user.Gender?.ToLower() == "masculino")
        {
            welcomeMessage = $"Bienvenido {user.Username}";
            welcomeClass = "welcome-male";
        }
        else if (user.Gender?.ToLower() == "femenino")
        {
            welcomeMessage = $"Bienvenida {user.Username}";
            welcomeClass = "welcome-female";
        }
        else
        {
            welcomeMessage = $"Bienvenido {user.Username}";
        }
    }

    ViewData["Title"] = "HabitTracker Pro";

    var last7Days = Enumerable.Range(0, 7)
        .Select(i => DateTime.Today.AddDays(-i))
        .Reverse()
        .ToList();

    var dailyCompletion = last7Days
        .Select(date => habits.Count(h => h.LastCheckDate == date && h.Completed))
        .ToList();
}

@if (user != null)
{
    if (!user.IsPremium)
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-center">
            <span>🚀 Estás en versión gratuita (máx 5 hábitos)</span>

            <a asp-controller="User" asp-action="Pay" class="btn btn-dark btn-sm">
                💳 Volverme Premium
            </a>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            👑 Eres usuario PREMIUM — sin límites 🔥
        </div>
    }
}

<div class="welcome-card @welcomeClass mb-4">
    <div class="welcome-content">
        <div class="welcome-avatar">
            @(username.Length > 0 ? username.Substring(0, 1).ToUpper() : "?")
        </div>

        <div>
            <h5 class="mb-1 fw-bold">@welcomeMessage</h5>
            <small>Disciplina diaria. Resultados extraordinarios.</small>
        </div>
    </div>
</div>

<div class="container mt-5" style="max-width:1200px;">

    <div class="text-center mb-4">
        <h1 class="fw-bold display-5">🚀 HabitTracker Pro</h1>
        <p class="opacity-75">Disciplina diaria. Resultados extraordinarios.</p>
    </div>
    <!-- KPIs -->
    <div class="row text-center mb-4">

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h6 class="text-muted">Hábitos</h6>
                <h3 class="fw-bold">@totalHabits</h3>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h6 class="text-muted">Racha Total</h6>
                <h3 class="fw-bold text-success">@totalStreak</h3>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h6 class="text-muted">Hoy</h6>
                <h3 class="fw-bold text-primary">@completionRate%</h3>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h6 class="text-muted">Mejor Récord</h6>
                <h3 class="fw-bold text-warning">@bestRecord</h3>
            </div>
        </div>

    </div>

    @if (user != null && user.IsPremium || Model.Count < 5)
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill">
            ➕ Nuevo hábito
        </a>
    }
    else
    {
        <a asp-controller="User" asp-action="Pay"
               class="btn btn-dark rounded-pill">
            🔒 Hazte Premium
        </a>
    }

    <!-- TABLA SIEMPRE VISIBLE -->
    <div class="card shadow rounded-4 p-4 mb-4 border-0">

        @if (Model.Count == 0)
        {
            <div class="text-center text-muted mb-3">
                Aún no tienes hábitos creados.
            </div>
        }

        <table class="table align-middle table-hover">
            <thead class="text-uppercase small text-muted">
                <tr>
                    <th>Hábito</th>
                    <th>Estado</th>
                    <th>Racha</th>
                    <th>Récord</th>
                    <th>Creado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (user != null && !user.IsPremium && Model.Count >= 5)
                {
                    <tr>
                        <td colspan="6">
                            <div class="alert alert-danger text-center mb-2">
                                🚫 Alcanzaste el límite de hábitos.
                                <a asp-controller="User" asp-action="Pay" class="fw-bold">
                                    Hazte premium 🔥
                                </a>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var habit in Model)
                {
                    <tr>
                        <td class="fw-semibold">@habit.Name</td>

                        <td>
                            @if (habit.LastCheckDate == DateTime.Today && habit.Completed)
                            {
                                <span class="badge bg-success">✔ Hoy</span>
                            }
                            else if (habit.LastCheckDate == DateTime.Today && !habit.Completed)
                            {
                                <span class="badge bg-danger">✖ Hoy</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pendiente</span>
                            }
                        </td>

                        <td class="fw-bold text-primary">@habit.StreakDays</td>

                        <td class="fw-bold text-warning">@habit.MaxStreak</td>

                        <td>
                            <small class="text-muted">
                                @habit.CreatedDate.ToString("dd MMM yyyy")
                            </small>
                        </td>

                        <td class="text-center">
                            <a href="/Habit/Complete/@habit.Id" class="btn btn-sm btn-outline-success rounded-pill me-1">✔</a>
                            <a href="/Habit/Fail/@habit.Id" class="btn btn-sm btn-outline-danger rounded-pill me-1">✖</a>
                            <a asp-action="Edit" asp-route-id="@habit.Id" class="btn btn-sm btn-outline-warning rounded-pill me-1">✏</a>
                            <a asp-action="Delete" asp-route-id="@habit.Id"
                                   class="btn btn-sm btn-outline-secondary rounded-pill"
                                   data-no-loader="true"
                                   onclick="if(!confirm('¿Eliminar hábito?')) return false;">
                                🗑
                            </a>
                        </td>
                    </tr>
                

                    <!-- 💬 FILA DE COMENTARIOS -->
                    <tr>
                        <td colspan="6">

                            <!-- FORM -->
                            <form asp-action="AddComment" method="post" class="mb-2">
                                <input type="hidden" name="habitId" value="@habit.Id" />

                                <input type="text"
                                       name="content"
                                       class="form-control form-control-sm"
                                       placeholder="💬 Escribe un comentario..." />
                            </form>

                            @if (habit.Comments != null && habit.Comments.Any())
                            {
                                foreach (var c in habit.Comments.OrderByDescending(x => x.CreatedAt))
                                {
                                    <div style="font-size:13px; padding-left:5px;">
                                        <b>@c.User.Username:</b> @c.Content
                                    </div>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- GRÁFICO SIEMPRE VISIBLE -->
    <div class="card shadow rounded-4 p-4 border-0">
        <h5 class="fw-bold mb-3">📈 Progreso últimos 7 días</h5>
        <canvas id="habitChart"></canvas>
    </div>

</div>

@section Scripts {
    <script>
        const labels=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(last7Days.Select(d => d.ToString("dd/MM"))));
        const data=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyCompletion));

        new Chart(document.getElementById('habitChart'),{
            type:'line',
            data:{
                labels:labels,
                datasets:[{
                    data:data,
                    borderWidth:3,
                    tension:0.4,
                    fill:true,
                    backgroundColor:'rgba(99,102,241,0.1)',
                    borderColor:'#6366f1'
                }]
            },
            options:{
                responsive:true,
                plugins:{legend:{display:false}},
                scales:{y:{beginAtZero:true,ticks:{precision:0}}}
            }
        });
    </script>
}

<style>
    .welcome-card {
        color: white;
        padding: 22px 26px;
        border-radius: 22px;
        box-shadow: 0 20px 45px rgba(0,0,0,0.18);
    }

    .welcome-male {
        background: linear-gradient(135deg, #2563eb, #1e3a8a);
    }

    .welcome-female {
        background: linear-gradient(135deg, #ec4899, #9d174d);
    }

    .welcome-neutral {
        background: linear-gradient(135deg, #6366f1, #7c3aed);
    }

    .welcome-content {
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .welcome-avatar {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        background: rgba(255,255,255,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: bold;
    }
</style>