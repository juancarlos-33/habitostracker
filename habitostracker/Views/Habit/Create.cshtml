@model HabitTrackerApp.Models.Habit

@{
    ViewData["Title"] = "Crear Hábito";
}

<div style="max-width:500px; margin: 30px auto;">

    <h4 class="fw-bold mb-4">✨ Crear nuevo hábito</h4>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3">@TempData["Error"]</div>
    }

    <div class="card shadow-sm border-0 rounded-4 p-4">
        <form asp-action="Create" method="post" onsubmit="return validarHabito()">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">Nombre del hábito *</label>
                <input type="text" id="habitName" asp-for="Name"
                       class="form-control rounded-pill"
                       placeholder="Ej: Leer 30 minutos"
                       oninput="limpiarError()" />
                <div id="nameError" class="mt-1" style="display:none;
                    color:#b91c1c; font-size:0.82rem;">
                    ⚠️ El nombre del hábito es obligatorio.
                </div>
            </div>

          

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    💾 Guardar hábito
                </button>
                <a href="/Habit" class="btn btn-outline-secondary rounded-pill px-4">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    function validarHabito() {
        const name = document.getElementById("habitName").value;
        const error = document.getElementById("nameError");

        if (!name || name.trim() === "") {
            error.style.display = "block";
            document.getElementById("habitName").style.borderColor = "#ef4444";
            return false;
        }

        return true;
    }

        document.addEventListener("DOMContentLoaded", function () {
        const loader = document.getElementById("globalLoader");
        if (loader) {
            loader.style.display = "none";
            loader.style.pointerEvents = "none";
        }
    });

    function limpiarError() {
        const error = document.getElementById("nameError");
        error.style.display = "none";
        document.getElementById("habitName").style.borderColor = "";
    }
</script>