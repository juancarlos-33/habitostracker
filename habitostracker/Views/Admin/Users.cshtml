@inject HabitTrackerApp.Data.HabitDbContext _context
@model List<HabitTrackerApp.Models.User>

    <form id="antiForgeryForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@{
    var myId = int.Parse(User.FindFirst("UserId").Value);

    var me = _context.Users.FirstOrDefault(u => u.Id == myId);

    var activeNow = Model.Count(u =>
        u.IsActive &&
        !u.IsBanned &&
        u.LastOnline != null &&
        (DateTime.Now - u.LastOnline.Value).TotalSeconds < 60
    );
}



<h2 class="mb-4">👥Usuarios registrados </h2>

@{
    var block = Context.RequestServices
        .GetService<HabitTrackerApp.Data.HabitDbContext>()
        .ConnectionBlocks
        .FirstOrDefault();

    bool isBlocked = block != null && block.IsBlocked;
}


    <div class="mb-4">

        @if (isBlocked)
        {
            <div class="alert alert-danger d-flex justify-content-between align-items-center">

                <span>🔴 Conexión bloqueada</span>

                <form asp-controller="Admin" asp-action="ToggleConnectionBlock" method="post">
                    <button class="btn btn-success"
                    onclick="return confirm('¿Restaurar la conexión del sistema?')">
                        🔓 Restaurar conexión global
                    </button>
                </form>

            </div>
        }
        else
        {
            <div class="alert alert-success d-flex justify-content-between align-items-center">

                <span>🟢 Conexión activa</span>

                @if (me.Role == "SuperAdmin")
                {
                    <form asp-controller="Admin" asp-action="ToggleConnectionBlock" method="post">
                        <button class="btn btn-danger"
                                onclick="return confirm('¿Seguro que deseas bloquear la conexión?')">
                            🔒 Bloquear conexión global
                        </button>
                    </form>
                }
                else if (me.Role == "Admin")
                {
                    <button type="button"
                            class="btn btn-danger"
                            onclick="pedirCodigoAdmin()">
                        🔒 Bloquear conexión global
                    </button>
                }
            </div>
           
        }

    </div>





<a asp-controller="Admin"
   asp-action="Reports"
   class="btn btn-danger mb-3">
    🚩 Ver publicaciones reportadas
</a>

<div class="row mb-4 text-center" style="max-width:900px;">

    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 rounded-4 p-3">
            <h6 class="text-muted">Usuarios</h6>
            <h3>@Model.Count</h3>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 rounded-4 p-3">
            <h6 class="text-muted">Baneados</h6>
            <h3 class="text-danger">@Model.Count(u => u.IsBanned)</h3>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 rounded-4 p-3">
            <h6 class="text-muted">Desactivados</h6>
            <h3 class="text-warning">@Model.Count(u => !u.IsActive)</h3>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 rounded-4 p-3">
            <h6 class="text-muted">Activos ahora</h6>
            <h3 class="text-success" id="activeUsers">@activeNow</h3>
        </div>
    </div>

</div>


@if (User.IsInRole("SuperAdmin"))
{
    <form asp-controller="Admin" asp-action="GenerateAccessCode" method="post">
        <button type="submit" class="btn btn-warning mb-3">
            🔑 Generar código de autorización
        </button>
    </form>
}

@if (TempData["GeneratedCode"] != null)
{
    <div class="alert alert-success text-center">
        Código generado: <strong>@TempData["GeneratedCode"]</strong> 🔐
    </div>
}

<input type="text"
       id="searchUser"
       class="form-control mb-3"
       placeholder="🔍 Buscar usuario..." />




<div class="table-responsive">
    <table class="table table-bordered table-hover">

    <thead class="table-dark">
        <tr>
            <th>Foto</th>
            <th>Usuario</th>
            <th>Email</th>
            <th>Estado</th>
            <th>Acciones</th>
            <th>IP</th>
            <th>Sistema</th>
<th>Dispositivo</th>
<th>Navegador</th>
        </tr>
    </thead>

        <tbody>
            @{
                var ipInfo = ViewBag.IpInfo as Dictionary<string, (string country, string region, string city, string isp)>;
            }

        @if (TempData["NewPassword"] != null)
        {
            <div class="alert alert-success">
                Nueva contraseña generada: <b>@TempData["NewPassword"]</b>
            </div>
        }

        @foreach (var user in Model)
        {
            var blockedIps = ViewBag.BlockedIps as List<string> ?? new List<string>();
            bool isBlockedIp = user.LastIp != null && blockedIps.Contains(user.LastIp);

                <tr class="user-row">

                <td>
                    @if (!string.IsNullOrEmpty(user.ProfileImage))
                    {
                        <img src="@user.ProfileImage" width="40" height="40" style="border-radius:50%" />
                    }
                    else
                    {
                        <div style="width:40px;height:40px;border-radius:50%;background:#2563eb;color:white;
                            display:flex;align-items:center;justify-content:center;font-weight:bold;">
                            @user.Username.Substring(0, 1).ToUpper()
                        </div>
                    }
                </td>
                    <td class="username">
                        @user.Username
                        @if (user.Role == "SuperAdmin")
                        {
                            <span class="badge bg-warning text-dark ms-1">👑 SUPER ADMIN</span>
                        }
                        else if (user.Role == "Admin")
                        {
                            <span class="badge bg-info text-dark ms-1">Admin</span>
                        }
                    </td>

                    <td>
                        @if (user.Role == "SuperAdmin")
                        {
                            <span class="text-muted">🔒 Privado</span>
                        }
                        else
                        {
                            @user.Email
                        }
                    </td>

                    <td id="status-@user.Id">
                        @if (user.IsBanned)
                        {
                            <span class="badge bg-danger">Baneado</span>
                        }
                        else if (!user.IsActive)
                        {
                            <span class="badge bg-warning text-dark">Desactivado</span>
                        }
                        else if (user.LastOnline != null && (DateTime.Now - user.LastOnline.Value).TotalSeconds < 60)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>

                    <!-- ACCIONES -->
                    <td>
                        <div class="d-flex flex-wrap gap-2">

                            @if (user.Role == "SuperAdmin")
                            {
                                <span class="badge bg-dark">Propietario</span>
                            }
                            else if (user.Id == myId)
                            {
                                <span class="badge bg-secondary">Tu cuenta</span>
                            }
                            else
                            {
                                if (!user.IsActive)
                                {
                                    <a asp-controller="Admin"
                                           asp-action="ReactivateUser"
                                           asp-route-id="@user.Id"
                                           class="btn btn-sm btn-outline-success rounded-pill"
                                          
                                           onclick="return confirm('¿Reactivar este usuario?')">
                                        🔓 Reactivar
                                    </a>
                                }
                                else if (user.IsBanned)
                                {
                                    <a asp-controller="Admin"
                                           asp-action="UnbanUser"
                                           asp-route-id="@user.Id"
                                           class="btn btn-sm btn-outline-success rounded-pill"
                                           
                                           onclick="return confirm('¿Desbanear este usuario?')">
                                        🔓 Desbanear
                                    </a>
                                }
                                else
                                {
                                    @if (user.Id != int.Parse(User.FindFirst("UserId").Value))
                                    {
                                       @if (User.IsInRole("SuperAdmin") || user.Role != "SuperAdmin")
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger rounded-pill"
                                                   
                                                    onclick="confirmDelete(@user.Id)">
                                                🔒 Desactivar
                                            </button>
                                        }

                                        @if (User.IsInRole("SuperAdmin") || user.Role != "SuperAdmin")
                                        {
                                            <a asp-controller="Admin"
                                                   asp-action="BanUser"
                                                   asp-route-id="@user.Id"
                                                   class="btn btn-sm btn-outline-warning rounded-pill"
                                                  
                                                   onclick="return confirm('¿Seguro que quieres banear este usuario?');">
                                                🚫 Banear
                                            </a>
                                        }

                                        @if (User.IsInRole("SuperAdmin"))
                                        {
                                            <a asp-controller="Admin" asp-action="DeleteUserPermanently"
                                                   asp-route-id="@user.Id"
                                                   class="btn btn-sm rounded-pill btn-delete"
                                                   onclick="return confirm('¿Eliminar este usuario permanentemente?')">

                                                💀 Eliminar
                                            </a>
                                        }
                                    }

                                    @if (User.IsInRole("SuperAdmin"))
                                    {
                                        if (user.Role == "Admin")
                                        {
                                            <a href="#"
                                                   class="btn btn-sm btn-outline-secondary rounded-pill"
                                                  
                                                   onclick="event.preventDefault(); confirmRemoveAdmin(@user.Id);">
                                                Quitar Admin
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Admin"
                                                   asp-action="MakeAdmin"
                                                   asp-route-id="@user.Id"
                                                   class="btn btn-sm btn-outline-primary rounded-pill"
                                             
                                                   onclick="return confirm('¿Seguro que quieres convertir a este usuario en administrador?');">
                                                Hacer Admin
                                            </a>
                                        }
                                    }
                                }

                                @if (User.IsInRole("SuperAdmin") && user.Id != myId)
                                {
                                    <form asp-controller="Admin"
                                          asp-action="ResetPassword"
                                          method="post"
                                          style="display:inline">

                                        <input type="hidden" name="userId" value="@user.Id" />

                                        <button class="btn btn-sm btn-outline-warning rounded-pill"
                                                onclick="return confirm('¿Resetear la contraseña de este usuario?');">
                                            🔑 Reset
                                        </button>

                                    </form>
                                }
                            }

                        </div>
                    </td>
                       



                

                <!-- IP + PAIS + BLOQUEO -->
                <td style="min-width:220px">

                        @if (user.Role == "SuperAdmin")
                        {
                            <span class="text-muted">—</span>
                        }
                        else
                        {
                            @user.LastIp
                        }
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:10px">

                            <span style="font-size:13px;line-height:1.2">
                                 
                                
                                @if (user.Role != "SuperAdmin"
                                && !string.IsNullOrEmpty(user.LastIp)
                                && ipInfo != null
                                && ipInfo.ContainsKey(user.LastIp))
                                    {
                                        <br />
                                        <small class="text-muted">
                                            🌍 @ipInfo[user.LastIp].country <br />
                                            🗺 @ipInfo[user.LastIp].region <br />
                                            🏙 @ipInfo[user.LastIp].city <br />
                                            📡 @ipInfo[user.LastIp].isp <br />

                                            @if (user.Latitude != null && user.Longitude != null)
                                            {
                                                <a target="_blank"
                                                       href="https://maps.google.com/?q=@(user.Latitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)),@(user.Longitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture))"
                                                       class="text-primary">
                                                    📍 Ver en mapa
                                                </a>
                                            }
                                        </small>
                                    }
                                    
                                    
                                    
                                    
                                    @if (user.Role == "SuperAdmin")
                                    {
                                        <br />
                                        <small class="text-muted">—</small>
                                    }
                               
                            </span>

                            @if (User.IsInRole("SuperAdmin") && user.Id != myId)
                            {
                                if (isBlockedIp)
                                {
                                    <form asp-controller="Admin"
                                    asp-action="UnblockIP"
                                    method="post"
                                    style="margin:0">

                                        <input type="hidden" name="ip" value="@user.LastIp" />

                                        <button class="btn btn-success btn-sm"

                                        onclick="return confirm('¿Desbloquear esta IP?')">
                                            🔓
                                        </button>

                                    </form>
                                }
                                else
                                {
                                   <form asp-controller="Admin" asp-action="BlockIP" method="post" style="margin:0"
      onsubmit="return confirm('¿Bloquear esta IP?')">
    
    <input type="hidden" name="ip" value="@user.LastIp" />

    <button type="submit" class="btn btn-danger btn-sm">
        🚫
    </button>
</form>
                                }
                            }

                        </div>
                    
                    
                   

                </td>

                    <!-- SISTEMA -->
                    <td>
                        @if (user.Role == "SuperAdmin")
                        {
                            <span class="text-muted">—</span>
                        }
                        else
                        {
                            @(string.IsNullOrEmpty(user.OperatingSystem) ? "—" : user.OperatingSystem)
                        }
                    </td>

                    <!-- DISPOSITIVO -->
                    <td>
                        @if (user.Role == "SuperAdmin")
                        {
                            <span class="text-muted">—</span>
                        }
                        else
                        {
                            @(string.IsNullOrEmpty(user.Device) ? "—" : user.Device)
                        }
                    </td>

                    <!-- NAVEGADOR -->
                    <td>
                        @if (user.Role == "SuperAdmin")
                        {
                            <span class="text-muted">—</span>
                        }
                        else
                        {
                            @(string.IsNullOrEmpty(user.Browser) ? "—" : user.Browser)
                        }
                    </td>

            </tr>
            
            


        }

        </tbody>
    </table>
</div>
<script>

    function confirmDelete(userId)
    {
        const confirmacion = confirm("¿Seguro que quieres desactivar este usuario?");

        if (confirmacion)
        {
            window.location.href = "/Admin/DeleteUser/" + userId;
        }
    }

    function confirmRemoveAdmin(userId)
    {
        const confirmacion = confirm("¿Seguro que quieres quitar los permisos de administrador a este usuario?");

        if (confirmacion)
        {
            window.location.href = "/Admin/RemoveAdmin/" + userId;
        }
    }

</script>


<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

    connection.start().catch(function (err) {
        return console.error(err.toString());
    });

    connection.on("UserOnline", function (userId) {

        const statusCell = document.getElementById("status-" + userId);

        if (statusCell)
        {
            statusCell.innerHTML = '<span class="badge bg-success">Activo</span>';
        }

    });

    connection.on("UserOffline", function (userId) {

        const statusCell = document.getElementById("status-" + userId);

        if (statusCell)
        {
            statusCell.innerHTML = '<span class="badge bg-secondary">Inactivo</span>';
        }

    });

</script>

<script>

    connection.on("UserOnline", function () {

        const counter = document.getElementById("activeUsers");

        if(counter)
        {
            let value = parseInt(counter.innerText);
            counter.innerText = value + 1;
        }

    });

    connection.on("UserOffline", function () {

        const counter = document.getElementById("activeUsers");

        if(counter)
        {
            let value = parseInt(counter.innerText);
            counter.innerText = Math.max(0, value - 1);
        }

    });

</script>

<script>

    let activeCount = 0;

    const activeUsersElement = document.getElementById("activeUsers");

    connection.on("UserOnline", function (userId) {

        activeCount++;

        if (activeUsersElement)
            activeUsersElement.innerText = activeCount;

    });

    connection.on("UserOffline", function (userId) {

        activeCount--;

        if (activeCount < 0) activeCount = 0;

        if (activeUsersElement)
            activeUsersElement.innerText = activeCount;

    });

    connection.on("ForceLogout", function (message) {
    alert(message);
    window.location.href = "/Account/Login";
    });

</script>
<script>
    function filterUsers() {
    const input = document.getElementById("searchUser").value.toLowerCase();
    const rows = document.querySelectorAll(".user-row");

    rows.forEach(row => {
    const username = row.querySelector(".username").innerText.toLowerCase();

    if (username.includes(input)) {
    row.style.display = "";
    } else {
    row.style.display = "none";
    }
    });
    }

    // 🔥 activar mientras escribe
    document.getElementById("searchUser").addEventListener("keyup", filterUsers);
</script>
<script>
function pedirCodigoAdmin() {
    document.getElementById("codeModal").style.display = "flex";
}

function cerrarModal() {
    const modal = document.getElementById("codeModal");

    modal.style.display = "none";

    document.getElementById("codeInput").value = "";
    document.getElementById("codeError").innerText = "";
}

function validarCodigo() {

    let codigo = document.getElementById("codeInput").value.replace(/\D/g, '');
    let error = document.getElementById("codeError");

    // ❌ vacío
    if (codigo === "") {
        error.innerText = "Debes escribir un código";
        return;
    }

    // 🔐 TOKEN ANTIFORGERY
    const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;

    fetch('/Admin/ValidateAccessCode', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': token
        },
        body: JSON.stringify({ code: codigo })
    })
    .then(res => res.json())
    .then(data => {

        if (!data.success) {
            error.innerText = "❌ Código incorrecto o ya utilizado";
            return;
        }

        cerrarModal();

        if (confirm("¿Seguro que deseas bloquear la conexión global?")) {

            fetch('/Admin/ToggleConnectionBlock', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token
                }
            })
            .then(() => location.reload());

        }

    })
    .catch(err => {
        console.error("ERROR:", err);
        error.innerText = "⚠️ Error al validar el código";
    });
}
</script>
<style>
    /* 🔥 BOTÓN ELIMINAR */
    .btn-delete {
    border: 1px solid #dc3545;
    color: #dc3545;
    background: transparent;
    }
    .code-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}

.code-box {
    background: #1f2937;
    padding: 20px;
    border-radius: 15px;
    width: 300px;
    text-align: center;
    color: white;
}

.code-box input {
    width: 100%;
    padding: 8px;
    border-radius: 8px;
    border: none;
    margin-top: 10px;
}

.code-error {
    color: #ff4d4d;
    font-size: 13px;
    margin-top: 5px;
}

.code-actions {
    margin-top: 10px;
    display: flex;
    justify-content: space-between;
}

    .btn-delete:hover {
    background: #dc3545;
    color: white;
    box-shadow: 0 0 10px rgba(220, 53, 69, 0.6);
    }

    /* 🌙 MODO OSCURO */
    body.dark-mode .btn-delete {
    border: 1px solid #ff4d4d;
    color: #ff4d4d;
    }

    body.dark-mode .btn-delete:hover {
    background: #ff4d4d;
    color: white;
    }
</style>

<div id="codeModal" class="code-modal">
    <div class="code-box">

        <h5>⚠️ Autorización requerida</h5>
         <p>Necesitas autorización para hacer esto.</p>
        <p>Ingresa el código de 5 dígitos</p>

       <input type="text"
       id="codeInput"
       maxlength="5"
       inputmode="numeric"
       placeholder="Código..."
       oninput="this.value = this.value.replace(/\D/g, '')" />

        <div id="codeError" class="code-error"></div>

        <div class="code-actions">
            <button onclick="validarCodigo()">Aceptar</button>
            <button onclick="cerrarModal()">Cancelar</button>
        </div>

    </div>
</div>

