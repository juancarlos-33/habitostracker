<h2 class="mb-4 fw-bold">📊 Estadísticas del sistema</h2>

<div class="row g-4">

    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4 text-center p-4">
            <h3 class="fw-bold">@ViewBag.TotalUsers</h3>
            <p class="text-muted">Usuarios registrados</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4 text-center p-4">
            <h3 class="fw-bold">@ViewBag.TotalHabits</h3>
            <p class="text-muted">Hábitos creados</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4 text-center p-4">
            <h3 class="fw-bold">@ViewBag.TotalMessages</h3>
            <p class="text-muted">Mensajes enviados</p>
        </div>
    </div>

</div>