@model List<HabitTrackerApp.Models.Message>

@{
    ViewData["Title"] = "Mensajes";
    var myId = int.Parse(User.FindFirst("UserId").Value);
}

<div class="container mt-4">

    <h2 class="mb-4">📨 Conversaciones</h2>

    <table class="table table-hover">

        <tbody>

            @if (!Model.Any())
            {
                <tr>
                    <td class="text-center text-muted">
                        No tienes mensajes todavía 📭
                    </td>
                </tr>
            }
            else
            {
                @foreach (var msg in Model)
                {
                    var otherUserId = msg.SenderId == myId ? msg.ReceiverId : msg.SenderId;
                    var otherUser = msg.SenderId == myId ? msg.Receiver : msg.Sender;
                    var username = otherUser?.Username ?? ("Usuario " + otherUserId);
                    var profileImage = otherUser?.ProfileImage;
                    var firstLetter = username?.Substring(0, 1).ToUpper();
                    <tr style="cursor:pointer"
                        onclick="window.location='/Message/Chat?userId=@otherUserId'">

                        <td>

                            <div class="d-flex align-items-center gap-3">

                                <!-- FOTO O INICIAL -->
                                @if (!string.IsNullOrEmpty(profileImage))
                                {
                                    <img src="@profileImage"
                                         style="width:45px;height:45px;border-radius:50%;object-fit:cover;"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div style="width:45px;height:45px;border-radius:50%;background:#2563eb;
                                        color:white;display:none;align-items:center;justify-content:center;
                                        font-weight:bold;font-size:18px;">
                                        @firstLetter
                                    </div>
                                }
                                else
                                {
                                    <div style="width:45px;height:45px;border-radius:50%;background:#2563eb;
                                        color:white;display:flex;align-items:center;justify-content:center;
                                        font-weight:bold;font-size:18px;">
                                        @firstLetter
                                    </div>
                                }
                                <div style="
                                            width:45px;
                                            height:45px;
                                            border-radius:50%;
                                            background:#2563eb;
                                            color:white;
                                            display:none;
                                            align-items:center;
                                            justify-content:center;
                                            font-weight:bold;
                                            font-size:18px;">
                                    @firstLetter
                                </div>

                                <div>

                                    <div class="fw-bold">
                                        @username
                                    </div>
                                    <div class="text-muted small" style="
                                        max-width: 300px;
                                        white-space: nowrap;
                                        overflow: hidden;
                                        text-overflow: ellipsis;">
                                        @if (!string.IsNullOrEmpty(msg.Content) && msg.Content.EndsWith(".webm"))
                                        {
                                            <span>🎤 Audio</span>
                                        }
                                        else
                                        {
                                            @msg.Content
                                        }
                                    </div>
                                </div>

                            </div>

                        </td>

                        <td class="text-end text-muted small">
                            @msg.SentAt.ToString("HH:mm")
                        </td>

                    </tr>
                }
            }

        </tbody>

    </table>

</div>