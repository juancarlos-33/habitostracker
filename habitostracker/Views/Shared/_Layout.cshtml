            }

           <button class="menu-toggle" data-no-loader onclick="toggleSidebar()">☰</button>

            <a class="navbar-brand" asp-controller="Habit" asp-action="Index">
                🚀 HabitTracker bro :v
                @if (isLoginPage)
                {
                    <span> | inicien sesión pajeros 😎</span>
                }
            </a>

            <button class="navbar-toggler"
        type="button"
