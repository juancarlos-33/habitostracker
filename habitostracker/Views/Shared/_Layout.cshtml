<!DOCTYPE html>
<html lang="es">
<head>


    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HabitTracker Pro</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>

body {
    font-family: 'Inter', sans-serif;
    transition: background 0.3s ease, color 0.3s ease;
}


.chat-bubble{
    padding:10px 14px;
    border-radius:18px;
    font-size:14px;
    line-height:1.4;
    display:inline-block;
    max-width:70%;
    word-wrap:break-word;
}

/* 🔵 tus mensajes */
.me-bubble{
    background:linear-gradient(135deg,#2563eb,#3b82f6);
    color:white;
    border-bottom-right-radius:4px;
}

/* ⚪ otros */
.other-bubble{
    background:#f1f5f9;
    color:#111827;
    border-bottom-left-radius:4px;
}

/* sombra suave */
.chat-bubble{
    box-shadow:0 2px 6px rgba(0,0,0,0.08);
}



/* NAVBAR */
.navbar {
    border-radius: 14px;
    margin: 12px;
    padding: 10px 20px;
    backdrop-filter: blur(10px);
    background: rgba(255,255,255,0.85) !important;
    box-shadow: 0 8px 25px rgba(0,0,0,0.08);
}

.navbar-brand {
    font-weight: 700;
    letter-spacing: 0.5px;
}

/* SIDEBAR OCULTO (modo botón) */
.sidebar{
    position:fixed;
    left:-240px;
    top:80px;
    width:240px;
    height:calc(100vh - 80px);
    background:#ffffff;
    border-right:1px solid #e5e7eb;
    padding:20px 10px;
    display:flex;
    flex-direction:column;
    gap:6px;
    z-index:1000;
    transition:left .3s ease;
}

/* cuando se abre */
.sidebar.show{
    left:0;
}

/* LOGO */
.sidebar-logo {
    font-size: 1.3rem;
    font-weight: 800;
    margin-bottom: 25px;

    display: flex;
    align-items: center;
    gap: 8px;

    color: white;

    padding: 10px 12px;
    border-radius: 10px;

    background: linear-gradient(135deg,#2563eb,#4f46e5);
    box-shadow: 0 4px 15px rgba(37,99,235,0.4);
}

/* LINKS */
.sidebar-link{
    display:flex;
    align-items:center;
    gap:12px;
    padding:10px 14px;
    border-radius:12px;
    text-decoration:none;
    color:#374151;
    font-weight:500;
    transition:all .2s ease;
}

.sidebar-link span{
    font-size:18px;
}

/* hover */
.sidebar-link:hover{
    background:#f3f4f6;
    transform:translateX(4px);
}

/* activo */
.sidebar-link.active{
    background:#2563eb;
    color:white;
}

.sidebar-link.active span{
    filter:drop-shadow(0 0 4px rgba(255,255,255,0.6));
}

/* CONTENIDO (pantalla completa) */
.main-content{
    margin-left:0;
    padding:30px;
    width:100%;
}

/* BOTÓN ☰ */
.menu-toggle{
    border:none;
    background:transparent;
    font-size:24px;
    margin-right:10px;
    cursor:pointer;
}

/* DROPDOWN */
.dropdown-menu{
    animation:dropdownFade 0.2s ease;
}

@@keyframes dropdownFade{
    from{
        opacity:0;
        transform:translateY(-6px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

.dropdown-item{
    border-radius:8px;
    transition:all .2s;
}

.dropdown-item:hover{
    background:#f1f5f9;
    transform:translateX(3px);
}

/* DARK MODE */
body.bg-dark .card {
    background-color: #1f1f2e !important;
    color: white !important;
}

body.bg-dark .table {
    color: white !important;
}

body.bg-dark .table thead {
    background-color: #2a2a3d !important;
}

body.bg-dark .modal-content {
    background-color: #1f1f2e;
    color: white;
}

/* AVATAR */
.user-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg,#2563eb,#7c3aed);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
}

.user-avatar-img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
}

/* LOADER */
#globalLoader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: white;
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
}

.loader-circle {
    width: 70px;
    height: 70px;
    border: 6px solid #e5e7eb;
    border-top: 6px solid #2563eb;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.loader-text {
    font-weight: 600;
    margin-top: 15px;
    letter-spacing: 1px;
    color: #111827;
}

.loader-sub {
    font-size: 14px;
    color: #6b7280;
}

/* OVERLAY */
#overlay{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.4);
    backdrop-filter:blur(3px);
    opacity:0;
    visibility:hidden;
    transition:all .3s ease;
    z-index:999;
}

#overlay.show{
    opacity:1;
    visibility:visible;
}

</style>
</head>

<body class="bg-light text-dark" id="appBody">

    <div id="overlay"></div>

 
<!-- 🔥 SIDEBAR -->
<div class="sidebar" id="sidebar">

    <div class="sidebar-logo">
        🚀 HabitTracker
    </div>

    <a class="sidebar-link" asp-controller="Habit" asp-action="Index">
        <span>🏠</span> Inicio
    </a>

    <a class="sidebar-link" asp-controller="Habit" asp-action="History">
        <span>📊</span> Historial
    </a>

    <a class="sidebar-link" asp-controller="Habit" asp-action="Calendar">
        <span>📅</span> Calendario
    </a>

    <a class="sidebar-link" asp-controller="Post" asp-action="Index">
        <span>📸</span> Publicaciones
    </a>

    <a class="sidebar-link" asp-controller="User" asp-action="Index">
        <span>👥</span> Amigos
    </a>

    <a class="sidebar-link" asp-controller="Support" asp-action="Chat">
        <span>😔</span> Me siento mal
    </a>

    <a class="sidebar-link" asp-controller="User" asp-action="FriendRequests">
        <span>📩</span> Solicitudes
    </a>

    <a class="sidebar-link" asp-controller="Post" asp-action="SavedPosts">
        <span>🔖</span> Guardados
    </a>

    <a class="sidebar-link" asp-controller="Account" asp-action="Security">
        <span>🔐</span> Seguridad
    </a>

    <a class="sidebar-link" asp-controller="Help" asp-action="Index">
        <span>🆘</span> Mesa de ayuda
    </a>
    @if (User.IsInRole("SuperAdmin"))
{
    <a class="sidebar-link" asp-controller="Admin" asp-action="Index">
        <span>🛡️</span> Centro de Seguridad
    </a>

    <a class="sidebar-link" asp-controller="Admin" asp-action="Payments">
        <span>💰</span> Pagos Premium
    </a>
}

</div>

<style>
