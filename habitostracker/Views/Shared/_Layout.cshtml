<span class="navbar-toggler-icon"></span>

</button>

            <div class="collapse navbar-collapse" id="mainNavbar">
<div class="d-flex align-items-center gap-3 ms-auto">

                        @if (User.Identity.IsAuthenticated)
                    {

                        

                       

                    <li class="nav-item">
