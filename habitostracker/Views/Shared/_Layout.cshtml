    // 🔥 Interceptar forms
    document.addEventListener("submit", function (e) {
        if (!isGuest) return;
        const form = e.target;
        if (!form.classList.contains("guest-block-form")) return;
        if (modalEl.contains(form)) return;
        e.preventDefault();
        guestModal.show();
    }, true);

    // 🔥 Botón cerrar
    document.getElementById("closeGuestModal").addEventListener("click", function () {
        guestModal.hide();
    });
});
