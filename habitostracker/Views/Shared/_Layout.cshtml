    <div style="width:200px;height:6px;background:rgba(255,255,255,0.2);
                border-radius:10px;margin-top:10px;overflow:hidden;">
        <div id="loaderBar" style="width:0%;height:100%;
             background:linear-gradient(90deg,#4ade80,#22c55e);
             transition:width 0.2s;"></div>
