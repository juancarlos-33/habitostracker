    <!-- CONTENIDO -->

<div class="layout">

    <div class="main-content">
        @RenderBody()
    </div>

</div>

    <!-- MODAL LOGOUT -->

    <div class="modal fade" id="logoutModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 shadow-lg border-0">
                <div class="modal-body text-center p-5">

                    <div style="font-size:50px;">🚪</div>

                    <h5 class="fw-bold mt-3">
                        ¿Seguro que deseas cerrar sesión bro?
                    </h5>

                    <p class="text-muted small">
                        Tendrás que volver a ingresar tus datos otra vez bro.
                    </p>

                    <div class="d-flex justify-content-center gap-3 mt-4">

                        <button type="button"
                                class="btn btn-secondary rounded-pill px-4"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <form asp-controller="Account"
                              asp-action="Logout"
                              method="post"
                              class="d-inline">

                            @Html.AntiForgeryToken()

                            <button type="submit"
                                    class="btn btn-danger rounded-pill px-4 shadow">
                                Sí, salir
                            </button>

                        </form>

                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- SCRIPTS -->

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>

        const isSuperAdmin = @(User.IsInRole("SuperAdmin").ToString().ToLower());

        const connectionGlobal = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();


        connectionGlobal.on("ForceLogout", function(message){

        document.body.innerHTML = `
        <div style="
        height:100vh;
        display:flex;
        align-items:center;
        justify-content:center;
        background:#0f172a;
        font-family:Inter;
        color:white;
        text-align:center;
        ">
        <div style="
        background:#1e293b;
        padding:50px;
        border-radius:14px;
        box-shadow:0 15px 40px rgba(0,0,0,0.6);
        ">
        <h2 style="color:#f59e0b">
        ⚠ Atención
        </h2>

        <p>${message}</p>

        <div style="
        margin-top:20px;
        border:4px solid #334155;
        border-top:4px solid #f59e0b;
        border-radius:50%;
        width:30px;
        height:30px;
        animation:spin 1s linear infinite;
        margin-left:auto;
        margin-right:auto;
        "></div>

        <p style="margin-top:10px;font-size:13px;opacity:0.7">
        Cerrando sesión...
        </p>
        </div>
        </div>

        <style>
        @@keyframes spin{
        0%{transform:rotate(0deg);}
        100%{transform:rotate(360deg);}
        }
        </style>
        `;

        setTimeout(function(){
        window.location.href="/Account/Login";
        },2500);

        });

        connectionGlobal.on("IPBlocked", function (blockedIp) {

        fetch("/Home/GetMyIP")
        .then(r => r.text())
        .then(myIp => {

        if (myIp === blockedIp) {

        document.body.innerHTML = `
        <div style="
        height:100vh;
        display:flex;
        align-items:center;
        justify-content:center;
        background:#0f172a;
        font-family:Inter;
        color:white;
        text-align:center;
        ">

        <div style="
        background:#1e293b;
        padding:50px;
        border-radius:14px;
        box-shadow:0 15px 40px rgba(0,0,0,0.6);
        ">

        <h2 style="color:#ef4444">
        🚫 IP bloqueada
        </h2>

        <p>
        Tu dirección IP ha sido bloqueada
        </p>

        <div style="
        margin-top:20px;
        border:4px solid #334155;
        border-top:4px solid #ef4444;
        border-radius:50%;
        width:30px;
        height:30px;
        animation:spin 1s linear infinite;
        margin-left:auto;
        margin-right:auto;
        "></div>

        <p style="margin-top:10px;font-size:13px;opacity:0.7">
        Cerrando conexión...
        </p>

        </div>

        </div>

        <style>
        @@keyframes spin{
        0%{transform:rotate(0deg);}
        100%{transform:rotate(360deg);}
        }
        </style>
        `;

        setTimeout(function(){
        window.location.href = "/Account/Login?ipblocked=true";
        },2500);

        }

        });

        });




        // 🚨 BLOQUEO GLOBAL
              connectionGlobal.on("ConnectionBlocked", function (message) {

            // ❌ Si es SuperAdmin no hacer nada
            if(isSuperAdmin){
                return;
            }

            alert(message);

            });

            setTimeout(function(){
               window.location.href = "/Home/ConnectionBlocked";
            },1500);

        });

        connectionGlobal.on("IPBlockedNow", function (message) {

        document.body.innerHTML = `
        <div style="
        height:100vh;
        display:flex;
        align-items:center;
        justify-content:center;
        background:#020617;
        color:white;
        font-family:Inter;
        text-align:center;
        ">
        <div style="
        background:#1e293b;
        padding:50px;
        border-radius:16px;
        box-shadow:0 20px 60px rgba(0,0,0,0.7);
        ">
        <h2 style="color:#ef4444">🚫 Acceso bloqueado</h2>
        <p>${message}</p>
        <p style="opacity:0.6">Redirigiendo...</p>
        </div>
        </div>
        `;

        setTimeout(function(){
        window.location.href = "/Account/Login?ipblocked=true";
        },2000);

        });

        
        connectionGlobal.on("UserDeleted", function (userId, username) {

        const myId = '@User.FindFirst("UserId")?.Value';

        if (myId == userId) {

        alert("⚠ Esta cuenta fue eliminada.");

        setTimeout(function () {
        window.location.href = "/Account/Login";
        }, 1500);
        }

        });


      

      

       connectionGlobal.on("IPBlocked", function (message) {

        document.body.innerHTML = `
        <div style="
        height:100vh;
        display:flex;
        align-items:center;
        justify-content:center;
        background:#020617;
        color:white;
        font-family:Inter;
        text-align:center;
        ">
        <div style="
        background:#1e293b;
        padding:50px;
        border-radius:16px;
        box-shadow:0 20px 60px rgba(0,0,0,0.7);
        ">
        <h2 style="color:#ef4444">🚫 Acceso bloqueado</h2>
        <p>${message}</p>
        <p style="opacity:0.7">Cerrando conexión...</p>
        </div>
        </div>
        `;

        setTimeout(function(){
        window.location.href = "/Account/Login?ipblocked=true";
        },2000);

        });

      

                       connectionGlobal.on("IPBlocked", function (blockedIp) {

            fetch("/Home/GetMyIP")
            .then(r => r.text())
            .then(myIp => {

                if (myIp === blockedIp) {

                    alert("🚫 Su dirección IP fue bloqueada por un administrador");

                    // cerrar conexión SignalR
                    connectionGlobal.stop();

                    // cerrar sesión
                    fetch("/Account/Logout", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        }
                    }).then(() => {

                        // redirigir
                        window.location.href = "/Account/Login?ipblocked=true";

                    });
                    }
                    

                }

            });

        });


        // 👤 NOTIFICACIÓN DE USUARIO CONECTADO
        connectionGlobal.on("UserConnectedNotification", function (username) {

            showAdminNotification(username);

        });


        // iniciar conexión
        connectionGlobal.start()
            .then(function () {
                console.log("SignalR conectado");
            })
            .catch(function (err) {
                console.error("Error SignalR:", err.toString());
            });


        

       

        // 🔔 notificación visual
        function showAdminNotification(username)
        {
            const box = document.createElement("div");

            box.innerHTML = `
                <div style="
                    background:#111827;
                    color:white;
                    padding:14px 18px;
                    border-radius:12px;
                    box-shadow:0 10px 25px rgba(0,0,0,0.3);
                    font-size:14px;
                    min-width:220px;
                ">
                    <strong>${username}</strong><br>
                    <span style="color:#22c55e;">● En línea</span>
