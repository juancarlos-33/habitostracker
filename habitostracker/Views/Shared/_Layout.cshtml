<!DOCTYPE html>
<html lang="es">
<head>


    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HabitTracker Pro</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">





<style>

body {
    font-family: 'Inter', sans-serif;
    transition: background 0.3s ease, color 0.3s ease;
}


.chat-bubble{
    padding:10px 14px;
    border-radius:18px;
    font-size:14px;
    line-height:1.4;
    display:inline-block;
    max-width:70%;
    word-wrap:break-word;
}

/* 🔵 tus mensajes */
.me-bubble{
    background:linear-gradient(135deg,#2563eb,#3b82f6);
    color:white;
    border-bottom-right-radius:4px;
}

/* 🔥 quitar azul del logo SIEMPRE */
.navbar-brand {
    color: #000 !important;
}

/* 🔥 modo oscuro */
body.bg-dark .navbar-brand {
    color: #fff !important;
}

/* 🔥 TEXTO GLOBAL EN MODO OSCURO */
body.bg-dark {
    color: #fff !important;
}

/* 🔥 EXCEPCIONES IMPORTANTES */
body.bg-dark input,
body.bg-dark textarea,
body.bg-dark select {
    background-color: #1e1e1e !important;
    color: #fff !important;
    border: 1px solid #444 !important;
}

/* placeholders */
body.bg-dark ::placeholder {
    color: #bbb !important;
}

/* 🔥 TODO texto dentro */
/* 🔥 TEXTO NORMAL */
body.bg-dark {
    color: #e4e6eb;
}

/* 🔥 TÍTULOS */
body.bg-dark h1,
body.bg-dark h2,
body.bg-dark h3,
body.bg-dark h4,
body.bg-dark h5 {
    color: #fff;
}

/* 🔥 LABELS (como "Filtrar por fecha") */
body.bg-dark label {
    color: #ccc !important;
}

/* 🔥 INPUTS */
body.bg-dark input,
body.bg-dark select {
    background-color: #1e1e1e !important;
    color: #fff !important;
    border: 1px solid #444;
}

/* 🔥 TABLAS */
body.bg-dark table {
    color: #fff;
}

body.bg-dark th {
    background-color: #2a2a2a;
    color: #fff;
}



/* 🔥 CARDS / CONTENEDORES */
body.bg-dark .card,
body.bg-dark .shadow-sm,
body.bg-dark .p-3,
body.bg-dark .p-4 {
    background-color: #1e1e1e !important;
    color: #fff !important;
    border: 1px solid #333 !important;
}



/* 🔥 FIX REAL */
body.bg-dark .sec-card {
    background: #1e1e1e !important;
    color: #fff !important;
    border: 1px solid #333;
}

/* 🔥 BLOQUES DESPLEGABLES */
body.bg-dark .sec-container > div {
    background-color: #1e1e1e !important;
    color: #fff !important;
}

body.bg-dark input {
    background-color: #121212 !important;
    color: #fff !important;
    border: 1px solid #444;
}

/* 🔥 CONTENEDOR CHAT */
body.bg-dark #chatBox {
    background-color: #121212 !important;
}
/* 🔥 MENSAJES (todos) */
body.bg-dark #chatBox > div > div {
    color: #fff !important;
}
body.bg-dark #chatBox > div[style*="flex-start"] > div {
    background-color: #2a2a2a !important;
    color: #fff !important;
}
/* 🔥 POSTS EN MODO OSCURO */
body.bg-dark .post-card {
    background-color: #1e1e1e !important;
    color: #fff !important;
    border: 1px solid #333;
}
body.bg-dark .post-description,
body.bg-dark .post-header {
    color: #fff !important;
}
/* 🔥 HELP / MESA DE AYUDA */
body.bg-dark .help-card {
    background-color: #1e1e1e !important;
    color: #fff !important;
    border: 1px solid #333;
}
body.bg-dark .help-card * {
    color: #fff;
}
/* 🔥 CONTACTOS (WHATSAPP / TIKTOK) */
body.bg-dark .help-contact {
    background-color: #1e1e1e !important;
    color: #fff !important;
    border: 1px solid #333;
}
/* 🔥 GUEST MODE DARK */
body.bg-dark .guest-container {
    background-color: #1e1e1e !important;
    color: #fff !important;
    border: 1px solid #333;
}
body.bg-dark .guest-info {
    background-color: #2a2a2a !important;
    color: #fff !important;
}
body.bg-dark .guest-container input {
    background-color: #121212 !important;
    color: #fff !important;
    border: 1px solid #444;
}
body.bg-dark .guest-container p,
body.bg-dark .guest-container label,
body.bg-dark .guest-container li {
    color: #ddd !important;
}
body.bg-dark .guest-container .btn-primary {
    background: linear-gradient(135deg, #4e73df, #224abe);
    border: none;
}
body.bg-dark .help-contact p,
body.bg-dark .help-contact a {
    color: #fff !important;
}
body.bg-dark .help-contact:hover {
    background-color: #2a2a2a;
}
body.bg-dark .help-card .text-muted {
    color: #bbb !important;
}
body.bg-dark .help-card {
    box-shadow: 0 8px 20px rgba(0,0,0,0.5);
}
body.bg-dark .post-image {
    background-color: #121212 !important;
}
body.bg-dark .post-image-container {
    background-color: #121212 !important;
}
body.bg-dark #chatBox > div[style*="flex-end"] > div {
    background: linear-gradient(135deg, #4e73df, #224abe);
    color: #fff !important;
}
body.bg-dark input {
    background-color: #1e1e1e !important;
    color: #fff !important;
}

/* 🔥 FIX BOTÓN CERRAR SESIONES */
body.bg-dark .sec-btn.danger {
    background: #842029 !important; /* rojo oscuro */
    color: #fff !important;
    border: none;
}

body.bg-dark .sec-btn.danger:hover {
    background: #a52834 !important;
}

.menu-toggle {
    width: auto !important;
    display: inline-block !important;
}

body.bg-dark .sec-toggle {
    background-color: #2a2a2a !important;
    color: #fff !important;
}

body.bg-dark .sec-danger {
    background-color: #3a1a1a !important;
    color: #ffb3b3 !important;
}

body.bg-dark .sec-card * {
    color: #fff;
}

/* 🔥 DROPDOWN (el menú del perfil) */
body.bg-dark .dropdown-menu {
    background-color: #1e1e1e;
    border: 1px solid #333;
}

body.bg-dark .dropdown-menu a {
    color: #fff !important;
}

body.bg-dark .dropdown-menu a:hover {
    background-color: #2a2a2a;
}
/* 🔥 quitar hover azul */
.navbar-brand:hover {
    color: #000 !important;
}

/* 🔥 NAVBAR BASE */
.navbar-custom {
    background: linear-gradient(145deg, #0f172a, #1e293b);
    border-radius: 20px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.4);
}

/* 🔥 BOTONES ☰ */
.nav-icon-btn {
    background: rgba(255,255,255,0.08);
    border: none;
    color: white;
    font-size: 20px;
    padding: 8px 12px;
    border-radius: 12px;
    transition: all 0.2s ease;
}

.nav-icon-btn:hover {
    background: rgba(255,255,255,0.2);
    transform: scale(1.05);
}

/* 🔥 BOTÓN MODO OSCURO */
.theme-btn {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    color: #facc15;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 16px;
    transition: all 0.3s ease;
}

.theme-btn:hover {
    background: rgba(255,255,255,0.2);
    transform: scale(1.05);
}

/* 🔥 TEXTO CON GRADIENTE */
.text-gradient {
    background: linear-gradient(90deg, #60a5fa, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

body.bg-dark .navbar-brand:hover {
    color: #fff !important;
}

/* ⚪ otros */
.other-bubble{
    background:#f1f5f9;
    color:#111827;
    border-bottom-left-radius:4px;
}

/* sombra suave */
.chat-bubble{
    box-shadow:0 2px 6px rgba(0,0,0,0.08);
}



/* NAVBAR */
.navbar {
    border-radius: 14px;
    margin: 12px;
    padding: 10px 20px;
    backdrop-filter: blur(10px);
    background: rgba(255,255,255,0.85) !important;
    box-shadow: 0 8px 25px rgba(0,0,0,0.08);
}

.navbar-brand {
    font-weight: 700;
    letter-spacing: 0.5px;
}

/* SIDEBAR OCULTO (modo botón) */
.sidebar{
    position:fixed;
    left:-240px;
    top:80px;
    width:240px;
    height:calc(100vh - 80px);
    background:#ffffff;
    border-right:1px solid #e5e7eb;
    padding:20px 10px;
    display:flex;
    flex-direction:column;
    gap:6px;
    z-index:1000;
    transition:left .3s ease;
}

/* cuando se abre */
.sidebar.show{
    left:0;
}

.bg-dark .card,
.bg-dark .list-group-item {
    background-color: #1e1e1e !important;
    color: #fff !important;
}

.bg-dark .card a,
.bg-dark .list-group-item a {
    color: #fff !important;
}

.bg-dark .text-dark {
    color: #fff !important;
}

.dropdown-item span:last-child {
  
    color: white;
    border-radius: 999px;
    padding: 2px 8px;
    font-size: 12px;
}

/* 🔥 MODO OSCURO - NOTIFICACIONES */
body.bg-dark .notification-card {
    background: #1e293b !important;
    color: #fff !important;
    border: 1px solid rgba(255,255,255,0.1);
}

/* TEXTO PRINCIPAL */
body.bg-dark .notification-message {
    color: #f1f5f9 !important;
}

/* TIEMPO */
body.bg-dark .notification-time {
    color: #94a3b8 !important;
}

@@media (min-width: 992px) {
    .navbar-toggler {
        display: none !important;
    }
}

.notification-card {
    border-radius: 15px;
    padding: 12px;
    transition: all 0.2s ease;
}

/* HOVER */
body.bg-dark .notification-card:hover {
    background: #334155 !important;
    transform: scale(1.01);
}

/* LOGO */
.sidebar-logo {
    font-size: 1.3rem;
    font-weight: 800;
    margin-bottom: 25px;

    display: flex;
    align-items: center;
    gap: 8px;

    color: white;

    padding: 10px 12px;
    border-radius: 10px;

    background: linear-gradient(135deg,#2563eb,#4f46e5);
    box-shadow: 0 4px 15px rgba(37,99,235,0.4);
}

/* LINKS */
.sidebar-link{
    display:flex;
    align-items:center;
    gap:12px;
    padding:10px 14px;
    border-radius:12px;
    text-decoration:none;
    color:#374151;
    font-weight:500;
    transition:all .2s ease;
}

.nav-icon-btn {
    color: inherit !important;
}
.nav-icon-btn {
    color: #ffffff !important;
}

.sidebar-link span{
    font-size:18px;
}

/* hover */
.sidebar-link:hover{
    background:#f3f4f6;
    transform:translateX(4px);
}

/* activo */
.sidebar-link.active{
    background:#2563eb;
    color:white;
}

.sidebar-link.active span{
    filter:drop-shadow(0 0 4px rgba(255,255,255,0.6));
}

/* CONTENIDO (pantalla completa) */
.main-content{
    margin-left:0;
    padding:30px;
    width:100%;
}

/* BOTÓN ☰ */
.menu-toggle{
    border:none;
    background:transparent;
    font-size:24px;
    margin-right:10px;
    cursor:pointer;
}

.bg-dark .username {
    color: #fff !important;
    font-weight: 500;
}

/* DROPDOWN */
.dropdown-menu{
    animation:dropdownFade 0.2s ease;
}

.theme-toggle {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 50%;
    padding: 12px;
    font-size: 18px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.4);
}

@@media (min-width: 992px) {
    .nav-left-toggle {
        display: none !important;
    }
}

@@keyframes dropdownFade{
    from{
        opacity:0;
        transform:translateY(-6px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

.dropdown-item{
    border-radius:8px;
    transition:all .2s;
}

.dropdown-item:hover{
    background:#f1f5f9;
    transform:translateX(3px);
}

/* DARK MODE */
body.bg-dark .card {
    background-color: #1f1f2e !important;
    color: white !important;
}

body.bg-dark .table {
    color: white !important;
}


body.bg-dark .table thead {
    background-color: #2a2a3d !important;
}

body.bg-dark .modal-content {
    background-color: #1f1f2e;
    color: white;
}
.modal-backdrop {
    pointer-events: none !important;
}

.modal {
    z-index: 1055 !important;
}

.navbar .d-flex {
    flex-wrap: nowrap !important;
}
#themeToggle,
.menu-toggle {
    flex-shrink: 0;
}
.menu-toggle {
    white-space: nowrap;
}

/* AVATAR */
.user-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg,#2563eb,#7c3aed);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
}

.user-avatar-img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
}

/* LOADER */
#globalLoader {
    position: fixed;
    top: 0;
    left: 0;
    height: 100%;
    background: white;
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
}
.navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.navbar .d-flex {
    flex-direction: row !important;
    flex-wrap: nowrap !important;
}
.menu-toggle {
    padding: 6px 10px;
}

.loader-circle {
    width: 70px;
    height: 70px;
    border: 6px solid #e5e7eb;
    border-top: 6px solid #2563eb;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.loader-text {
    font-weight: 600;
    margin-top: 15px;
    letter-spacing: 1px;
    color: #111827;
}

.loader-sub {
    font-size: 14px;
    color: #6b7280;
}

/* OVERLAY */
#overlay{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.4);
    backdrop-filter:blur(3px);
    opacity:0;
    visibility:hidden;
    transition:all .3s ease;
    z-index:999;
}

#overlay.show{
    opacity:1;
    visibility:visible;
}

</style>
</head>

<body data-is-guest="@(User.FindFirst("IsGuest")?.Value ?? "false")">

    <div id="overlay"></div>

 
<!-- 🔥 SIDEBAR -->
<div class="sidebar" id="sidebar">

    <div class="sidebar-logo">
        🚀 HabitTracker
    </div>

    <a class="sidebar-link" asp-controller="Habit" asp-action="Index">
        <span>🏠</span> Inicio
    </a>

    <a class="sidebar-link" asp-controller="Habit" asp-action="History">
        <span>📊</span> Historial
    </a>

    <a class="sidebar-link" asp-controller="Habit" asp-action="Calendar">
        <span>📅</span> Calendario
    </a>

   <a class="sidebar-link guest-block" asp-controller="Post" asp-action="Index">
    <span>📸</span> Publicaciones
</a>
<a class="sidebar-link guest-block" asp-controller="User" asp-action="Index">
    <span>👥</span> Amigos
</a>

    <a class="sidebar-link guest-block" asp-controller="Support" asp-action="Chat">
        <span>😔</span> Me siento mal
    </a>

    <a class="sidebar-link guest-block" asp-controller="User" asp-action="FriendRequests">
        <span>📩</span> Solicitudes
    </a>

    <a class="sidebar-link guest-block" asp-controller="Post" asp-action="SavedPosts">
        <span>🔖</span> Guardados
    </a>

   <a class="sidebar-link guest-block" asp-controller="Account" asp-action="Security">
    <span>🔐</span> Seguridad
</a>

<a class="sidebar-link guest-block" asp-controller="Help" asp-action="Index">
    <span>🆘</span> Mesa de ayuda
</a>
    @if (User.IsInRole("SuperAdmin"))
{
    <a class="sidebar-link" asp-controller="Admin" asp-action="Index">
        <span>🛡️</span> Centro de Seguridad
    </a>

    <a class="sidebar-link" asp-controller="Admin" asp-action="Payments">
        <span>💰</span> Pagos Premium
    </a>
}

</div>

<style>
/* 🔥 OCULTO POR DEFECTO */
.sidebar {
    width: 240px;
    height: 100vh;
    background: linear-gradient(180deg, #0f172a, #1e293b);
    padding: 20px 15px;
    position: fixed;
    left: -260px; /* 👈 escondido */
    top: 0;
    color: white;
    display: flex;
    flex-direction: column;
    transition: 0.3s ease;
    z-index: 9999;
}

/* 🔥 EVITAR FLASH AZUL */
.navbar {
    background-color: #ffffff !important;
}

/* 🔥 MODO OSCURO */
body.bg-dark .navbar {
    background-color: #121212 !important;
}

/* 🔥 evitar estilos bootstrap iniciales */
.navbar-light,
.bg-white {
    background-color: #ffffff !important;
}

/* 🔥 NAVBAR NORMAL (modo claro) */
.custom-navbar {
    background-color: #ffffff;
}

/* 🔥 NAVBAR MODO OSCURO */
body.bg-dark .custom-navbar {
    background-color: #121212 !important;
}

/* 🔥 TEXTO CLARO */
body.bg-dark .custom-navbar * {
    color: #fff !important;
}

/* 🔥 CUANDO SE ABRE */
.sidebar.open {
    left: 0;
}

/* resto igual */
.sidebar-logo {
    font-size: 1.3rem;
    font-weight: 800;
    margin-bottom: 25px;
    text-align: center;
}

.sidebar-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    margin-bottom: 8px;
    border-radius: 10px;
    color: #cbd5f5;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
}

.sidebar-link span {
    font-size: 1.2rem;
}

.sidebar-link:hover {
    background: rgba(255,255,255,0.08);
    color: white;
    transform: translateX(5px);
}

.sidebar-link.active {
    background: linear-gradient(135deg,#2563eb,#4f46e5);
    color: white;
    box-shadow: 0 4px 15px rgba(37,99,235,0.4);
}
</style>

<script>
// 🔥 BOTÓN DE LAS 3 RAYITAS
function toggleSidebar(){
    document.getElementById("sidebar").classList.toggle("open");
}
</script>

 

</div>
    <div id="appNotification"
         style="position:fixed;
            top:20px;
            right:20px;
            background:#0d6efd;
            color:white;
            padding:12px 18px;
            border-radius:8px;
            display:none;
            z-index:9999;
            box-shadow:0 4px 10px rgba(0,0,0,0.2);">
    </div>
   <!-- LOADER GLOBAL -->
<div id="globalLoader" style="
    position:fixed; top:0; left:0;
    width:100%; height:100%;
    display:none; flex-direction:column;
    justify-content:center; align-items:center;
    z-index:9999;
    backdrop-filter: blur(6px);
    background: rgba(0,0,0,0.1);
    animation: fadeIn 0.3s ease;
">
    <img src="https://media.tenor.com/N5fU8iyU9F4AAAAj/shigure-ui-dance.gif"
         style="width:180px;height:180px;
                filter:drop-shadow(0 0 15px rgba(0,0,0,0.25));
                animation: bounce 1.5s infinite;" />

    <span style="margin-top:10px;font-size:14px;opacity:0.9;animation: fadeText 1.5s infinite;">
        Cargando...
    </span>

    <div style="width:200px;height:6px;background:rgba(255,255,255,0.2);
                border-radius:10px;margin-top:10px;overflow:hidden;">
        <div id="loaderBar" style="width:0%;height:100%;
             background:linear-gradient(90deg,#4ade80,#22c55e);
             transition:width 0.2s;"></div>
    </div>
</div>

<style>
    @@keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
    @@keyframes bounce { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-10px); } }
    @@keyframes fadeText { 0%,100% { opacity:0.4; } 50% { opacity:1; } }
</style>
</div>
    <!-- NAVBAR -->
    @if (User.Identity.IsAuthenticated && Context.Request.Query["blocked"] != "true")
    {




   <nav class="navbar navbar-expand-lg border-bottom px-4 shadow-sm sticky-top custom-navbar">
      
        <div class="container-fluid">

            @{
                var isLoginPage = Context.Request.Path.Value?.Contains("/Account/Login") ?? false;
            }

        
  <div class="d-flex align-items-center w-100 px-2 py-2 navbar-custom">

    <!-- ☰ IZQUIERDO -->
   <button class="nav-icon-btn nav-left-toggle" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
    ☰
</button>

    <!-- 🚀 TÍTULO -->
    <a class="navbar-brand mx-auto fw-bold text-gradient" asp-controller="Habit" asp-action="Index">
        🚀 HabitTracker
    </a>

    <!-- DERECHA -->
    <div class="d-flex align-items-center gap-2">

        <!-- 🌙 -->
        <button onclick="toggleDarkMode()" data-no-loader class="theme-btn">
            🌙
        </button>

        <!-- ☰ DERECHO -->
        <button class="nav-icon-btn" data-no-loader onclick="toggleSidebar()">
            ☰
