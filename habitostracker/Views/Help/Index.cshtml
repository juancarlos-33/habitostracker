@{
    ViewData["Title"] = "Mesa de ayuda";
}


<div class="help-container">

    @if (TempData["Success"] != null)
    {
        <div class="help-success">
            <img src="/images/hola.jpeg" />
            <p>@TempData["Success"]</p>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="help-error">
            <p>@TempData["Error"]</p>
        </div>
    }

    <!-- FOTO FUNDADORES -->
    <div class="help-card text-center">
        <img src="~/images/hole.png" class="help-img" />
        <h4 class="mt-3">Fundadores del proyecto</h4>
        <p class="text-muted">
            Estamos construyendo esta app para ayudarte cada día 🚀
        </p>
    </div>

    <div class="help-founders">
        <p>
            🚀 Este es nuestro primer proyecto como desarrolladores de software.
            <br />
            Estamos construyendo una aplicación enfocada en el control de hábitos,
            con el objetivo de ayudarte a superarte cada día y vencerte a ti mismo.
            <br /><br />
            Actualmente nos encontramos en el segundo semestre de desarrollo,
            aprendiendo y mejorando constantemente 💡
        </p>
    </div>

    <!-- FORMULARIO -->
    <div class="help-card">
        <h5>💡 Envíanos tu recomendación</h5>
        <p class="text-muted">Tu opinión nos ayuda a mejorar</p>

        <form method="post" asp-controller="Help" asp-action="SendFeedback">
            <textarea name="message" class="help-input" placeholder="Escribe tu recomendación..." required></textarea>

            <button type="submit" class="help-btn">
                Enviar recomendación
            </button>
        </form>
    </div>

    <div class="help-card text-center">
        <h5>📞 ¿Necesitas ayuda personalizada?</h5>
        <p class="text-muted">Contáctanos directamente</p>

        <div class="help-socials">

            <!-- WHATSAPP -->
            <div class="help-contact">
                <p>🟢 WhatsApp</p>

                <a href="https://wa.me/573106013616?text=Hola%20Juan,%20necesito%20ayuda%20con%20la%20app%20HabitTracker"
                       target="_blank" class="help-link">
                    Contactar a Juan Carlos
                </a>

                <a href="https://wa.me/573233748757?text=Hola,%20necesito%20ayuda%20con%20la%20app%20HabitTracker"
                       target="_blank" class="help-link">
                    Contactar a Juan Esteban
                </a>
            </div>

            <!-- TIKTOK -->
            <div class="help-contact">
                <p>🎵 TikTok</p>

                <a href="https://www.tiktok.com/@@holasoyjuancarlos_" target="_blank" class="help-link">
                    Ver perfil de Juan Carlos
                </a>

                <a href="https://www.tiktok.com/@@j_eelunico" target="_blank" class="help-link">
                    Ver perfil de Juan Esteban
                </a>
            </div>

        </div>
    </div>

</div>

<style>
    .help-container {
        max-width: 600px;
        margin: 40px auto;
    }

    .help-founders {
        margin-top: 15px;
        font-size: 0.9rem;
        color: #6b7280;
        text-align: center;
        line-height: 1.5;
    }


    .help-socials {
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
        margin-top: 15px;
    }

    .help-contact {
        background: #f8fafc;
        padding: 15px;
        border-radius: 12px;
        min-width: 180px;
    }

    .help-link {
        display: block;
        margin-top: 8px;
        text-decoration: none;
        font-weight: 600;
        color: #2563eb;
    }

        .help-link:hover {
            text-decoration: underline;
        }

    .help-card {
        background: white;
        padding: 20px;
        border-radius: 15px;
        margin-bottom: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }

    .help-img {
        width: 120px;
        border-radius: 15px;
    }

    .help-input {
        width: 100%;
        height: 100px;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #ccc;
        margin-bottom: 10px;
    }

    .help-success {
        background: #ecfdf5;
        border: 1px solid #10b981;
        padding: 15px;
        border-radius: 12px;
        text-align: center;
        margin-bottom: 20px;
    }

        .help-success img {
            width: 60px;
            border-radius: 10px;
            margin-bottom: 10px;
        }

    .help-error {
        background: #fef2f2;
        border: 1px solid #dc2626;
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 15px;
        color: #b91c1c;
        text-align: center;
    }

    .help-btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg,#2563eb,#4f46e5);
        color: white;
        font-weight: 600;
    }

    .help-socials {
        display: flex;
        justify-content: center;
        gap: 20px;
    }

        .help-socials a {
            text-decoration: none;
            font-weight: 600;
        }
</style>